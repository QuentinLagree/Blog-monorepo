{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": true,
    "assets": [
      {
        "include": "src/commons/mailing/mail/templates/*",
        "outDir": "dist/commons/mailing/mail/templates"
      }
    ],
    "watchAssets": true
    
  }
}
