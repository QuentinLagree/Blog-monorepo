model Post {
  id          Int     @id @default(autoincrement())
  authorId    Int
  title       String
  description String
  content     String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  published_at DateTime?

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("post")
}
